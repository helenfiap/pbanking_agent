# ── LLM Provider ──────────────────────────────────────────────
# Set to "gemini" (free tier) or "azure" (if you have credits)
LLM_PROVIDER=gemini

# ── Gemini (Google AI Studio — free tier) ─────────────────────
GOOGLE_API_KEY=your_google_api_key_here
# gemini-2.0-flash → 1,500 req/day free (use for dev/testing)
# gemini-2.5-flash → 20 req/day free (use for final demo only)
GEMINI_MODEL=gemini-2.0-flash

# ── Azure OpenAI (optional — better SQL quality) ──────────────
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_key_here

# ── LangFuse (observability — free tier) ──────────────────────
LANGFUSE_SECRET_KEY="sk-lf-a28212b1-5e4b-49ec-8925-505969e6fd0d"
LANGFUSE_PUBLIC_KEY="pk-lf-76e36d01-6554-411e-b454-d07b29b5cf20"
LANGFUSE_BASE_URL="https://us.cloud.langfuse.com"                                                              +
