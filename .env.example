# ── LLM Provider ───────────────────────────────────────────────────────────────
# "gemini" → Google AI Studio (free tier, default)
# "azure"  → Azure AI Foundry (GPT-4o / GPT-4.1)
# "azure-41" | "azure-kimi" | "azure-grok" | "azure-nano" → outros modelos Foundry
LLM_PROVIDER=gemini

# ── Gemini (Google AI Studio — free tier) ──────────────────────────────────────
# Gere sua chave em: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here
# Opcional: segunda chave para rotação e dobrar quota diária
GOOGLE_API_KEY_2=your_second_google_api_key_here
# gemini-2.5-flash → 20 req/dia free (demo)
# gemini-2.0-flash-lite → 1.500 req/dia free (desenvolvimento)
GEMINI_MODEL=gemini-2.5-flash

# ── Azure AI Foundry (opcional) ────────────────────────────────────────────────
# Endpoint no formato: https://<resource>.services.ai.azure.com/openai/v1
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_API_KEY=your_azure_foundry_key_here

# ── LangFuse (observabilidade — free tier) ─────────────────────────────────────
# Crie sua conta em: https://us.cloud.langfuse.com
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
